# ---- Cinelog environment ----
# Copy to .env and fill in values.
#
# For DOCKER self-hosting, only these four are read from this file (the rest are
# set inside docker-compose.yml): JWT_ACCESS_SECRET, JWT_REFRESH_SECRET,
# TMDB_API_KEY, TMDB_ACCESS_TOKEN. For local `pnpm dev`, all of them apply.

# Runtime data directory (artwork cache, uploads). Resolved relative to the
# API's working directory (apps/api) in dev; an absolute mounted volume in Docker.
DATA_DIR=./data

# SQLite connection string used by Prisma.
# Path is resolved relative to the schema file (apps/api/prisma), so this points
# at apps/api/data/cinelog.db — the same folder as DATA_DIR above.
# In Docker this is overridden to an absolute path (file:/data/cinelog.db).
DATABASE_URL="file:../data/cinelog.db"

# API
API_PORT=3000
# Comma-separated allowed origins for CORS (the web app dev server).
CORS_ORIGINS=http://localhost:5173

# Auth secrets — CHANGE THESE. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Metadata providers
TMDB_API_KEY=
# TMDB read-access token (v4) is also supported; leave blank to use API key.
TMDB_ACCESS_TOKEN=

# Web (Vite) — base URL of the API as seen by the browser
VITE_API_URL=http://localhost:3000
