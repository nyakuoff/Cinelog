{
  "name": "cinelog",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted media watchlist & review platform",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @cinelog/api prisma generate",
    "db:migrate": "pnpm --filter @cinelog/api prisma migrate dev",
    "db:studio": "pnpm --filter @cinelog/api prisma studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
