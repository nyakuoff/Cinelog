// Cinelog — Prisma schema (SQLite).
//
// Notes on SQLite constraints (deliberate design choices):
//  - Prisma enums are unsupported on SQLite, so enum-like columns are String
//    and validated by the shared Zod contracts at the API boundary.
//  - JSON blobs are stored as String (Json scalar support on SQLite varies by
//    version); we serialize/parse in the service layer.
//  - Arrays are modeled as relations (e.g. Genre m:n) or JSON strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         String   @default("USER") // UserRole: ADMIN | USER
  avatarUrl    String?
  bannerUrl    String?
  bio          String?
  ratingScale  String   @default("TEN") // RatingScale
  settings     String   @default("{}") // JSON: misc per-user prefs

  // Letterboxd live sync: pulls the user's public diary RSS feed on demand.
  letterboxdUsername String?
  letterboxdSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens  RefreshToken[]
  statuses       UserMediaStatus[]
  watchHistory   WatchHistory[]
  ratings        Rating[]
  episodeRatings EpisodeRating[]
  artwork        UserArtwork[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Canonical cached media metadata (shared across all users)
// ---------------------------------------------------------------------------

model MediaItem {
  id             String   @id @default(cuid())
  type           String // MediaType
  provider       String // ProviderId
  externalId     String
  title          String
  originalTitle  String?
  releaseDate    String?
  runtime        Int?
  overview       String?
  tagline        String?
  posterPath     String? // provider path/URL; served via the artwork proxy
  backdropPath   String?
  logoPath       String?
  providerRating Float? // provider's own average, normalized 0..100
  rawMetadata    String   @default("{}") // JSON: full provider detail (cast, crew, studios, trailer, artwork options)
  castOverride   String? // JSON: CreditPerson[] set by an admin; takes precedence over rawMetadata.cast
                         // and is never touched by cacheDetails/rematch, so it survives provider re-fetches.
  cachedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  genres   Genre[]           @relation("MediaGenres")
  statuses UserMediaStatus[]
  history  WatchHistory[]
  ratings  Rating[]
  seasons  Season[]
  artwork  UserArtwork[]

  @@unique([provider, externalId])
  @@index([type])
  @@map("media_items")
}

// Per-user artwork override: lets a user pick a different poster/backdrop than
// the media's default, from the set of images the provider offers. Never
// affects other users. Absence of a row means "use the provider default".
model UserArtwork {
  id          String   @id @default(cuid())
  userId      String
  mediaItemId String
  type        String // ArtworkKind: POSTER | BACKDROP
  url         String // raw provider source URL (proxied for display at read time)
  createdAt   DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  media MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId, type])
  @@index([mediaItemId])
  @@map("user_artwork")
}

// ---------------------------------------------------------------------------
// Seasons & episodes (first-class; cached from the provider)
// ---------------------------------------------------------------------------

model Season {
  id           String   @id @default(cuid())
  mediaItemId  String
  seasonNumber Int
  name         String?
  overview     String?
  posterPath   String?
  airDate      String?
  episodeCount Int      @default(0)
  cachedAt     DateTime @default(now())

  media    MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([mediaItemId, seasonNumber])
  @@index([mediaItemId])
  @@map("seasons")
}

model Episode {
  id            String   @id @default(cuid())
  seasonId      String
  episodeNumber Int
  name          String?
  overview      String?
  stillPath     String?
  airDate       String?
  runtime       Int?

  season  Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  ratings EpisodeRating[]

  @@unique([seasonId, episodeNumber])
  @@index([seasonId])
  @@map("episodes")
}

// Per-user episode rating (normalized 0..100). Season/show averages are
// computed from these — never stored.
model EpisodeRating {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([episodeId])
  @@map("episode_ratings")
}

model Genre {
  id    String @id @default(cuid())
  name  String @unique
  media MediaItem[] @relation("MediaGenres")

  @@map("genres")
}

// ---------------------------------------------------------------------------
// Per-user tracking (the isolation boundary)
// ---------------------------------------------------------------------------

model UserMediaStatus {
  id            String    @id @default(cuid())
  userId        String
  mediaItemId   String
  status        String? // TrackingStatus | null
  isFavorite    Boolean   @default(false)
  isWatchlisted Boolean   @default(false)
  rewatchCount  Int       @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  media MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId])
  @@index([userId])
  @@map("user_media_status")
}

model WatchHistory {
  id          String   @id @default(cuid())
  userId      String
  mediaItemId String
  watchedAt   DateTime @default(now())
  isRewatch   Boolean  @default(false)

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  media MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mediaItemId])
  @@map("watch_history")
}

// Per-user rating. Season/episode targets (nullable FKs) arrive with the
// episodes phase; Phase 1 rates media only.
model Rating {
  id          String   @id @default(cuid())
  userId      String
  mediaItemId String
  value       Float // normalized 0..100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  media MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaItemId])
  @@index([mediaItemId])
  @@map("ratings")
}

// ---------------------------------------------------------------------------
// Artwork cache & global settings
// ---------------------------------------------------------------------------

model ArtworkCache {
  id          String   @id @default(cuid())
  sourceUrl   String   @unique
  localPath   String
  hash        String
  bytes       Int
  contentType String?
  fetchedAt   DateTime @default(now())

  @@map("artwork_cache")
}

model Setting {
  key   String @id
  value String // JSON

  @@map("settings")
}
